# Shell-readable defaults used by main.sh.

PROJECT_NAME="kgp-ptv-shet-burden"
GENOME_BUILD="GRCh38"
GNOMAD_VERSION="4.1"
CADD_VERSION="1.7"

DEFAULT_CHROMOSOMES="1-22"
DEFAULT_THREADS="4"

RESOURCES_DIR="resources"
WORK_DIR="work"
RESULTS_DIR="results"
LOGS_DIR="logs"
DOWNLOADS_DIR="downloads"
DEFAULT_KGP_DIR=""
KGP_1000G_RAW_BASE="https://ftp.1000genomes.ebi.ac.uk/vol1/ftp/data_collections/1000G_2504_high_coverage/working/20201028_3202_raw_GT_with_annot"
STREAM_1000G_MERGE_GAP="10000"

VEP_RELEASE="115"
GENCODE_RELEASE="47"

GNOMAD_ABSENT_POLICY="treat_absent_as_zero_but_flag"
GNOMAD_PRIMARY_AF_FIELDS="AF_joint,AF_joint_nfe,AF_joint_fin,fafmax_faf95_max_joint"

CADD_THRESHOLD="25"
MAX_EXTERNAL_LOOKUP_AC="1"

KGP_REQUIRE_SITE_PASS="1"
KGP_MIN_GQ="20"
KGP_MIN_DP="10"
KGP_HET_AB_MIN="0.2"
KGP_HET_AB_MAX="0.8"
KGP_REQUIRE_HET_AB="0"

GTEX_ENABLE_DEFAULT="0"
